#!/bin/sh

pgrep -x sxhkd > /dev/null || sxhkd &

# Второй монитор: ориентация и сторона (см. Docs/MASTER_INSTALL_russian.md в bspwm-myconf)
# export BSPWM_EXTERNAL_ROTATE=right   # normal | right | left | inverted
export BSPWM_EXTERNAL_POSITION=left    # left | right
sh $HOME/.config/bspwm/dual_monitors.sh

# Window borders (Auto-Generate)
bspc config focus_follows_pointer true
bspc config focused_border_color "#7899FA"
bspc config normal_border_color "#1f222b"
bspc config border_width 5
bspc config borderless_monocle true

bspc config active_border_color "#bd93f9"
bspc config presel_feedback_color "#6272a4"

# fix pointer
xsetroot -cursor_name left_ptr

# gaps
bspc config gapless_monocle false
bspc config window_gap 17

# moving floating windows and resize them with mouse, hold alt key
bspc config pointer_modifier mod4
bspc config pointer_action1 move
bspc config pointer_action2 resize_side
bspc config pointer_action3 resize_corner

# rules
bspc rule -a feh state=floating

# start resources
xrdb merge ~/.Xresources

# Random Wallpaper Script
sh $HOME/bin/default_wallpaper

# Run polybar
~/.config/polybar/launch.sh &

# Run touchpad conf
libinput-gestures-setup start

# Run multiple windows
bspc monitor -d 1 2 3 4 5

# Окна должны занимать доступную область без "щелей" по краям
bspc config top_padding 0
bspc config bottom_padding 0
bspc config left_padding 0
bspc config right_padding 0

# launch notification daemon
dunst -config $HOME/.config/bspwm/dunstrc &

# launch battery tracker and redshift
pkill battery-alert; ~/bin/battery-alert &
pgrep -x redshift > /dev/null || redshift &

# start compositor
picom --config $HOME/.config/bspwm/picom_configurations/1.conf &

# == autostart ==
"$HOME/bin/xdg-portal-sync-env.sh"

pkill flameshot; flameshot &

# run cursor tracker
pkill cursor_tracker ; ~/bin/cursor_tracker.sh
